# QQ Bot panel local settings
# Copy to .env or export equivalent variables before starting the server.

QQ_BOT_PANEL_USERNAME=admin
QQ_BOT_PANEL_PASSWORD=change-me
QQ_BOT_SESSION_SECRET=replace-with-a-long-random-string

# Runtime server
PORT=8001
QQ_BOT_TRUST_PROXY=0
QQ_BOT_COOKIE_SECURE=0
QQ_BOT_MAX_STORED_MESSAGES=20000

# Image fetching safety
# Default hosts allow common QQ/Tencent image CDNs. Add comma-separated host suffixes only if needed.
QQ_BOT_IMAGE_ALLOWED_HOSTS=qpic.cn,gtimg.cn,qq.com,nt.qq.com.cn,tencent.com,myqcloud.com
QQ_BOT_IMAGE_FETCH_TIMEOUT_MS=8000
QQ_BOT_ALLOW_LOCAL_IMAGE_FETCH=0

# Login rate limit
QQ_BOT_LOGIN_RATE_WINDOW_MS=900000
QQ_BOT_LOGIN_RATE_MAX=10
