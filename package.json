{
  "name": "qq-bot",
  "private": true,
  "version": "1.0.0",
  "description": "QQ Bot management panel and OneBot server.",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development QQ_BOT_VITE_DEV=1 tsx watch --clear-screen=false lib/server/index.ts",
    "start": "tsx lib/server/index.ts",
    "server:start": "tsx lib/server/index.ts",
    "server:dev": "NODE_ENV=development QQ_BOT_VITE_DEV=1 tsx watch --clear-screen=false lib/server/index.ts",
    "panel:dev": "NODE_ENV=development QQ_BOT_VITE_DEV=1 tsx watch --clear-screen=false lib/server/index.ts",
    "bot:restart": "bash scripts/restart.sh restart",
    "bot:stop": "bash scripts/restart.sh stop",
    "bot:status": "bash scripts/restart.sh status",
    "panel:build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "server:build": "tsc -p tsconfig.json",
    "build": "pnpm server:build && pnpm panel:build",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.app.json --noEmit",
    "check:server": "tsc -p tsconfig.json --noEmit",
    "check:app": "tsc -p tsconfig.app.json --noEmit",
    "test": "node --import tsx --test tests/server/*.test.ts",
    "migrate:sqlite": "tsx scripts/migrate-json-to-sqlite.ts",
    "preview:ai": "tsx scripts/preview-ai-runtime.ts"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "axios": "^1.7.9",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.0.0"
  },
  "packageManager": "pnpm@11.7.0"
}
