{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "moduleDetection": "force",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "express-session"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "lib/server/**/*.ts",
    "scripts/**/*.ts",
    "tests/server/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
